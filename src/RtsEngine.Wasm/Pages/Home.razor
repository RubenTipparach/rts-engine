@page "/"
@using RtsEngine.Wasm.Engine
@inject IJSRuntime JS
@implements IDisposable

<div id="game-container">
    <canvas id="glCanvas"></canvas>
    <div id="hud">
        <div class="hud-title">Silk.NET WASM Engine</div>
        <div class="hud-stat">Speed: @SpeedDisplay</div>
        <div class="hud-stat">VelX: @VelXDisplay &nbsp; VelY: @VelYDisplay</div>
        <div class="hud-hint">Drag to spin &bull; Scroll to boost &bull; Tap for impulse &bull; DblClick to reset</div>
    </div>
</div>

@code {
    private GameEngine? _engine;
    private WebGLRenderBackend? _app;
    private CubeRenderer? _cube;

    private string SpeedDisplay => _engine?.SpeedMagnitude.ToString("F2") ?? "---";
    private string VelXDisplay => _engine?.VelocityX.ToString("F2") ?? "---";
    private string VelYDisplay => _engine?.VelocityY.ToString("F2") ?? "---";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // 1. Init GL context (like sokol_gfx setup)
        var glOk = await GL.Init(JS, "glCanvas");
        if (!glOk) return;

        // 2. Init app shell — canvas + input + loop (like sokol_app setup)
        _app = new WebGLRenderBackend(JS);
        await _app.InitializeAsync("glCanvas");

        // 3. Create GPU resources — all through GL.* calls in C#
        _cube = new CubeRenderer();
        await _cube.Setup();

        // 4. Run engine — pure C#, zero platform awareness
        _engine = new GameEngine(_app, _cube);
        _engine.OnFrameRendered += () => InvokeAsync(StateHasChanged);
        _engine.Run();
    }

    public void Dispose()
    {
        _cube?.Dispose();
        _app?.Dispose();
    }
}
