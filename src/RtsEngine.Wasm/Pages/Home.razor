@page "/"
@using RtsEngine.Core
@using RtsEngine.Game
@using RtsEngine.Wasm.Engine
@inject IJSRuntime JS
@inject HttpClient Http
@implements IDisposable

<div id="game-container">
    <canvas id="gpuCanvas"></canvas>
    <div id="hud">
        @if (_mode == EditorMode.PlanetEdit)
        {
            <div class="hud-title">Planet Editor — @_planetName</div>
            <div class="hud-hint">
                Drag orbit &bull; Scroll zoom &bull; L-click raise &bull; R-click lower
                &bull; <a href="javascript:void(0)" @onclick="GoToSolarSystem" style="color:#0ff;text-decoration:underline;">⬅ Solar System</a>
            </div>
        }
        else if (_mode == EditorMode.SolarSystem)
        {
            <div class="hud-title">Solar System</div>
            <div class="hud-hint">Click a planet to edit &bull; Drag orbit &bull; Scroll zoom</div>
        }
        else
        {
            <div class="hud-title">Star Map — @_starMapLevel</div>
            <div class="hud-hint">Click to select &bull; [Backspace] Zoom out &bull; [Tab] Solar System</div>
        }
        <div id="gpu-errors" style="color:#ff9090;font-size:11px;max-height:60px;overflow:auto;"></div>
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div style="color:#ff9090;font-size:11px;">@_errorMessage</div>
        }
    </div>
</div>

@code {
    private GameEngine? _engine;
    private WebGLRenderBackend? _app;
    private PlanetRenderer? _planet;
    private StarMapRenderer? _starMap;
    private SolarSystemRenderer? _solarSystem;
    private IGPU? _gpu;
    private string? _errorMessage;
    private EditorMode _mode = EditorMode.SolarSystem;
    private string _starMapLevel = "Galaxy";
    private string _planetName = "Earth";
    private string _currentConfig = "planets/earth.yaml";
    private bool _loadingPlanet;

    private void GoToSolarSystem()
    {
        if (_engine != null) _engine.Mode = EditorMode.SolarSystem;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            var gpu = new WebGPU(JS);
            if (!await gpu.Init("gpuCanvas"))
            {
                _errorMessage = await JS.InvokeAsync<string>("GPUProxy.getInitError")
                    ?? "WebGPU init failed.";
                StateHasChanged();
                return;
            }
            _gpu = gpu;

            _app = new WebGLRenderBackend(JS);
            await _app.InitializeAsync("gpuCanvas");

            // Solar system
            var solarData = SolarSystemData.CreateDefault();
            var starmapShader = await Http.GetStringAsync("shaders/starmap.wgsl");
            var outlineShader = await Http.GetStringAsync("shaders/outline.wgsl");
            _solarSystem = new SolarSystemRenderer(gpu, solarData);
            await _solarSystem.Setup(starmapShader, outlineShader);

            // Star map
            var galaxy = GalaxyData.Generate(seed: 42);
            _starMap = new StarMapRenderer(gpu, galaxy);
            await _starMap.Setup(starmapShader);

            // Planet editor (default Earth)
            _planet = await CreatePlanetRenderer("planets/earth.yaml");

            // Engine
            _engine = new GameEngine(_app, _planet, _starMap, _solarSystem);
            _engine.Mode = EditorMode.SolarSystem;
            _engine.OnFrameRendered += OnFrame;
            _engine.Run();
        }
        catch (Exception e)
        {
            _errorMessage = e.Message;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void OnFrame()
    {
        if (_engine == null) return;
        _mode = _engine.Mode;
        _starMapLevel = _starMap?.Level.ToString() ?? "";

        var wanted = _engine.SelectedPlanetConfig;
        if (wanted != null && wanted != _currentConfig && !_loadingPlanet)
        {
            _loadingPlanet = true;
            _ = LoadPlanetAsync(wanted);
        }

        InvokeAsync(StateHasChanged);
    }

    private async Task LoadPlanetAsync(string configPath)
    {
        try
        {
            var newPlanet = await CreatePlanetRenderer(configPath);
            var old = _planet;
            _planet = newPlanet;
            _engine?.SetPlanetRenderer(newPlanet);
            old?.Dispose();
        }
        catch (Exception e)
        {
            _errorMessage = $"Load {configPath}: {e.Message}";
        }
        finally
        {
            _loadingPlanet = false;
        }
    }

    private async Task<PlanetRenderer> CreatePlanetRenderer(string configPath)
    {
        if (_gpu == null) throw new InvalidOperationException("GPU not initialized");

        var yaml = await Http.GetStringAsync(configPath);
        var config = PlanetConfig.FromYaml(yaml);
        var shader = await Http.GetStringAsync("shaders/terrain.wgsl");

        var mesh = new PlanetMesh(
            subdivisions: config.Subdivisions,
            radius: config.Radius,
            stepHeight: config.StepHeight);
        mesh.GenerateFromNoise(
            seed: config.Generation.Seed,
            frequency: config.Generation.Frequency,
            thresholds: config.Generation.Thresholds.ToArray());

        var renderer = new PlanetRenderer(_gpu, mesh);
        renderer.ApplyConfig(config);
        await renderer.Setup(shader);

        var atmoShader = await Http.GetStringAsync("shaders/atmosphere.wgsl");
        await renderer.SetupAtmosphere(atmoShader);

        var outlineShader = await Http.GetStringAsync("shaders/outline.wgsl");
        await renderer.SetupOutline(outlineShader);

        _planetName = config.Name;
        _currentConfig = configPath;
        return renderer;
    }

    public void Dispose()
    {
        _planet?.Dispose();
        _starMap?.Dispose();
        _solarSystem?.Dispose();
        _app?.Dispose();
    }
}
