@page "/"
@using RtsEngine.Core
@using RtsEngine.Game
@using RtsEngine.Wasm.Engine
@inject IJSRuntime JS
@inject HttpClient Http
@implements IDisposable

<div id="game-container">
    <canvas id="gpuCanvas"></canvas>
    <div id="gpu-errors" style="position:absolute;top:4px;left:4px;color:#ff9090;font-size:11px;max-height:60px;overflow:auto;pointer-events:none;z-index:10;"></div>
</div>

@code {
    private GameEngine? _engine;
    private WebGLRenderBackend? _app;
    private PlanetRenderer? _planet;
    private StarMapRenderer? _starMap;
    private SolarSystemRenderer? _solarSystem;
    private IGPU? _gpu;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            var gpu = new WebGPU(JS);
            if (!await gpu.Init("gpuCanvas")) return;
            _gpu = gpu;

            _app = new WebGLRenderBackend(JS);
            await _app.InitializeAsync("gpuCanvas");

            // Solar system
            var solarData = SolarSystemData.CreateDefault();
            var solarShader = await Http.GetStringAsync("shaders/solarsystem.wgsl");
            var outlineShader = await Http.GetStringAsync("shaders/outline.wgsl");
            var sunShader = await Http.GetStringAsync("shaders/sun.wgsl");
            var starfieldShader = await Http.GetStringAsync("shaders/starfield.wgsl");
            _solarSystem = new SolarSystemRenderer(gpu, solarData);
            await _solarSystem.Setup(solarShader, outlineShader, sunShader, starfieldShader);

            // Star map
            var galaxy = GalaxyData.Generate(seed: 42);
            var starmapShader = await Http.GetStringAsync("shaders/starmap.wgsl");
            _starMap = new StarMapRenderer(gpu, galaxy);
            await _starMap.Setup(starmapShader);

            // Planet (default Earth)
            _planet = await CreatePlanetRenderer("planets/earth.yaml");

            // Engine config (camera tuning, RTS ground view, LOD, lighting)
            EngineConfig engineConfig;
            try
            {
                var engineYaml = await Http.GetStringAsync("config/engine.yaml");
                engineConfig = EngineConfig.FromYaml(engineYaml);
            }
            catch { engineConfig = new EngineConfig(); }

            // RTS gameplay (buildings + units). Optional — falls back to a
            // pure planet editor if either the config or shader is missing.
            RtsConfig? rtsConfig = null;
            RtsRenderer? rtsRenderer = null;
            try
            {
                var rtsYaml = await Http.GetStringAsync("config/rts.yaml");
                rtsConfig = RtsConfig.FromYaml(rtsYaml);
                var rtsShader = await Http.GetStringAsync("shaders/rts.wgsl");
                rtsRenderer = new RtsRenderer(gpu, rtsConfig);
                await rtsRenderer.Setup(rtsShader);
            }
            catch { rtsConfig = null; rtsRenderer = null; }

            // Engine
            _engine = new GameEngine(_app, gpu, _planet, _starMap, _solarSystem,
                engineConfig, rtsRenderer, rtsConfig);
            _engine.Mode = EditorMode.SolarSystem;

            _engine.SetupUI();

            // Planet hot-swap callback
            _engine.OnFrameRendered += () =>
            {
                var wanted = _engine.SelectedPlanetConfig;
                if (wanted != null && !_loading)
                {
                    if (wanted == _currentConfig)
                    {
                        _engine.SwitchToPlanetEdit();
                    }
                    else
                    {
                        _loading = true;
                        _ = LoadPlanetAsync(wanted);
                    }
                }
            };

            _engine.Run();
        }
        catch (Exception e)
        {
            await JS.InvokeVoidAsync("eval",
                $"document.getElementById('gpu-errors').textContent = {System.Text.Json.JsonSerializer.Serialize(e.Message)}");
        }
    }

    private string _currentConfig = "planets/earth.yaml";
    private bool _loading;

    private async Task LoadPlanetAsync(string configPath)
    {
        try
        {
            var newPlanet = await CreatePlanetRenderer(configPath);
            var old = _planet;
            _planet = newPlanet;
            _engine?.SetPlanetRenderer(newPlanet);
            _engine?.SwitchToPlanetEdit();
            old?.Dispose();
        }
        catch (Exception e)
        {
            await JS.InvokeVoidAsync("eval",
                $"document.getElementById('gpu-errors').textContent = 'Load: ' + {System.Text.Json.JsonSerializer.Serialize(e.Message)}");
        }
        finally { _loading = false; }
    }

    private async Task<PlanetRenderer> CreatePlanetRenderer(string configPath)
    {
        if (_gpu == null) throw new InvalidOperationException("GPU not initialized");
        var yaml = await Http.GetStringAsync(configPath);
        var config = PlanetConfig.FromYaml(yaml);
        var shader = await Http.GetStringAsync("shaders/terrain.wgsl");

        var mesh = new PlanetMesh(
            subdivisions: config.Subdivisions,
            radius: config.Radius,
            stepHeight: config.StepHeight);
        mesh.GenerateFromNoise(
            seed: config.Generation.Seed,
            frequency: config.Generation.Frequency,
            thresholds: config.Generation.Thresholds.ToArray());

        var renderer = new PlanetRenderer(_gpu, mesh);
        renderer.ApplyConfig(config);
        await renderer.Setup(shader);

        var atmoShader = await Http.GetStringAsync("shaders/atmosphere.wgsl");
        await renderer.SetupAtmosphere(atmoShader);

        var outlineShader = await Http.GetStringAsync("shaders/outline.wgsl");
        await renderer.SetupOutline(outlineShader);

        _currentConfig = configPath;
        return renderer;
    }

    public void Dispose()
    {
        _planet?.Dispose();
        _starMap?.Dispose();
        _solarSystem?.Dispose();
        _app?.Dispose();
    }
}
