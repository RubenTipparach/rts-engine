@page "/"
@using RtsEngine.Wasm.Engine
@inject IJSRuntime JS
@implements IDisposable

<div id="game-container">
    <canvas id="glCanvas"></canvas>
    <div id="hud">
        <div class="hud-title">Silk.NET WASM Engine</div>
        <div class="hud-stat">Speed: @SpeedDisplay</div>
        <div class="hud-stat">VelX: @VelXDisplay &nbsp; VelY: @VelYDisplay</div>
        <div class="hud-hint">Drag to spin &bull; Scroll to boost &bull; Tap for impulse &bull; DblClick to reset</div>
    </div>
</div>

@code {
    private GameEngine _engine = new();
    private DotNetObjectReference<Home>? _dotnetRef;
    private bool _initialized;

    private string SpeedDisplay => _engine.SpeedMagnitude.ToString("F2");
    private string VelXDisplay => _engine.VelocityX.ToString("F2");
    private string VelYDisplay => _engine.VelocityY.ToString("F2");

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotnetRef = DotNetObjectReference.Create(this);
            _initialized = await JS.InvokeAsync<bool>("WebGLEngine.init", "glCanvas", _dotnetRef);
            if (_initialized)
            {
                await JS.InvokeVoidAsync("WebGLEngine.startLoop");
            }
        }
    }

    [JSInvokable]
    public async Task GameLoopTick()
    {
        _engine.Update();

        // Get canvas aspect ratio
        var aspect = 16f / 9f;
        try
        {
            var width = await JS.InvokeAsync<double>("eval", "document.getElementById('glCanvas').width");
            var height = await JS.InvokeAsync<double>("eval", "document.getElementById('glCanvas').height");
            if (height > 0) aspect = (float)(width / height);
        }
        catch { }

        var mvp = _engine.GetMvpMatrix(aspect);
        await JS.InvokeVoidAsync("WebGLEngine.render", mvp);

        StateHasChanged();
    }

    [JSInvokable]
    public void OnPointerDrag(float dx, float dy)
    {
        _engine.ApplyDragVelocity(dx, dy);
    }

    [JSInvokable]
    public void OnScrollWheel(float delta)
    {
        _engine.ApplyScrollBoost(delta);
    }

    [JSInvokable]
    public void OnTapStart()
    {
        _engine.ApplyTapBoost();
    }

    [JSInvokable]
    public void OnReset()
    {
        _engine.Reset();
    }

    public void Dispose()
    {
        _ = JS.InvokeVoidAsync("WebGLEngine.dispose");
        _dotnetRef?.Dispose();
    }
}
