@page "/"
@using RtsEngine.Core
@using RtsEngine.Game
@using RtsEngine.Wasm.Engine
@inject IJSRuntime JS
@inject HttpClient Http
@implements IDisposable

<div id="game-container">
    <canvas id="gpuCanvas"></canvas>
    <div id="gpu-errors" style="position:absolute;top:4px;left:4px;color:#ff9090;font-size:11px;max-height:60px;overflow:auto;pointer-events:none;z-index:10;"></div>
</div>

@code {
    // Home.razor is a compile/host shim only — it brings up WebGPU + the JS
    // app shell, then hands everything to the shared EngineBootstrap. Game
    // setup logic lives in RtsEngine.Game so Desktop hits the same code path.

    private EngineBootstrap? _boot;
    private WebGLRenderBackend? _app;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            var gpu = new WebGPU(JS);
            if (!await gpu.Init("gpuCanvas"))
            {
                // Surface the JS-side init reason so mobile users (where
                // WebGPU support is patchy — iOS Safari < 18.2 has none, and
                // some Android Chromes need flags) don't just see a blank
                // canvas.
                var reason = await gpu.GetInitError();
                if (string.IsNullOrEmpty(reason))
                    reason = "WebGPU init failed (no further detail). Try a recent Chrome/Edge desktop, or Safari 18.2+ on iOS / Chrome 121+ on Android.";
                await JS.InvokeVoidAsync("eval",
                    $"document.getElementById('gpu-errors').textContent = {System.Text.Json.JsonSerializer.Serialize(reason)};" +
                    "document.getElementById('gpu-errors').style.maxHeight = '200px';" +
                    "document.getElementById('gpu-errors').style.fontSize = '14px';");
                return;
            }

            _app = new WebGLRenderBackend(JS);
            await _app.InitializeAsync("gpuCanvas");

            _boot = new EngineBootstrap(gpu, _app, new HttpAssetSource(Http));
            await _boot.SetupAsync();
            _boot.HookPlanetHotSwap();
            _boot.Engine!.Run();
        }
        catch (Exception e)
        {
            await JS.InvokeVoidAsync("eval",
                $"document.getElementById('gpu-errors').textContent = {System.Text.Json.JsonSerializer.Serialize(e.Message)}");
        }
    }

    public void Dispose()
    {
        _boot?.Planet?.Dispose();
        _boot?.StarMap?.Dispose();
        _boot?.SolarSystem?.Dispose();
        _app?.Dispose();
    }
}
