@page "/"
@using RtsEngine.Core
@using RtsEngine.Game
@using RtsEngine.Wasm.Engine
@inject IJSRuntime JS
@inject HttpClient Http
@implements IDisposable

<div id="game-container">
    <canvas id="gpuCanvas"></canvas>
    <div id="hud">
        <div class="hud-title">Silk.NET WASM Engine (WebGPU)</div>
        <div class="hud-stat">Speed: @SpeedDisplay</div>
        <div class="hud-stat">VelX: @VelXDisplay &nbsp; VelY: @VelYDisplay</div>
        <div class="hud-hint">Drag to spin &bull; Release to throw</div>
    </div>
</div>

@code {
    private GameEngine? _engine;
    private WebGLRenderBackend? _app;
    private CubeRenderer? _cube;

    private string SpeedDisplay => _engine?.SpeedMagnitude.ToString("F2") ?? "---";
    private string VelXDisplay => _engine?.VelocityX.ToString("F2") ?? "---";
    private string VelYDisplay => _engine?.VelocityY.ToString("F2") ?? "---";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // Platform GPU backend
        var gpu = new WebGPU(JS);
        if (!await gpu.Init("gpuCanvas")) return;

        // App shell
        _app = new WebGLRenderBackend(JS);
        await _app.InitializeAsync("gpuCanvas");

        // Game renderer — uses IGPU, lives in Game, no platform awareness
        var shaderCode = await Http.GetStringAsync("shaders/cube.wgsl");
        _cube = new CubeRenderer(gpu);
        await _cube.Setup(shaderCode);

        // Engine
        _engine = new GameEngine(_app, _cube);
        _engine.OnFrameRendered += () => InvokeAsync(StateHasChanged);
        _engine.Run();
    }

    public void Dispose()
    {
        _cube?.Dispose();
        _app?.Dispose();
    }
}
